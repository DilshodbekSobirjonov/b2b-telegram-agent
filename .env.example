# ─── Infrastructure only — business config lives in PostgreSQL ────────────────

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/b2b_telegram_agent

# Redis
REDIS_URL=redis://localhost:6379/0

# Auth
# IMPORTANT: use a long random string in production
JWT_SECRET_KEY=change-me-to-a-long-random-secret

# Server
SERVER_PORT=8000

# Public HTTPS URL where Telegram will POST webhook updates.
# Local dev: use ngrok → https://xxxx.ngrok.io
# Production: https://api.yourdomain.com
WEBHOOK_BASE_URL=https://api.yourdomain.com

# Frontend
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000
